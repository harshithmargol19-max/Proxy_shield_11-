MONGODB_URI=mongodb://localhost:27017/proxyshield11
PORT=3000

NODE_ENV=development

PROXY_ENGINE_PORT=3001
ENABLE_SMTP=false
SMTP_PORT=2525

MONGODB_URI=mongodb://localhost:27017/email_fraud_db

EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

SMTP_HOST=localhost
SMTP_PORT=2525
SMTP_USER=smtp-user
SMTP_PASS=smtp-password

REQUIRE_AUTH=false
API_KEY=your-api-key-here
AUTH_TOKEN=your-auth-token-here

FRAUD_THRESHOLD=50

# Proxy Email Generation Strategy
# Options: "subaddress" (free, uses Gmail+ addressing) or "domain" (requires your own domain)
PROXY_EMAIL_STRATEGY=subaddress

# For subaddress strategy: Set your catch-all Gmail/Outlook
# All proxy emails become: yourname+shield_xxx@gmail.com
CATCH_ALL_EMAIL=yourproxyshield@gmail.com

# For domain strategy: Set your domain with catch-all routing (via Cloudflare, etc.)
# PROXY_DOMAIN=mail.yourdomain.com

# Hyperledger Fabric Configuration
FABRIC_CONFIG_PATH=./fabric-config
FABRIC_CONNECTION_PROFILE=./fabric-config/connection-org1.json
FABRIC_WALLET_PATH=./fabric-config/wallet
FABRIC_MSP_ID=Org1MSP
FABRIC_IDENTITY=appUser
FABRIC_PEER_ENDPOINT=localhost:7051
FABRIC_PEER_HOST_ALIAS=peer0.org1.example.com
FABRIC_TLS_CERT_PATH=./fabric-config/tls/ca.crt
