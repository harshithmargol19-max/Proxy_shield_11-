{
  "name": "email-fraud-middleware",
  "version": "1.0.0",
  "description": "Middleware for detecting fraudulent emails before delivering to users",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "dev": "nodemon server/server.js",
    "client": "npm start --prefix client",
    "install-client": "npm install --prefix client",
    "dev-full": "concurrently \"npm run dev\" \"npm run client\""
  }, 
  "keywords": [
    "email",
    "fraud-detection",
    "phishing",
    "mern",
    "middleware"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "body-parser": "^1.20.2",
    "concurrently": "^8.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.18.2",
    "mailparser": "^3.6.4",
    "mongoose": "^8.0.0",
    "nodemailer": "^6.9.7",
    "smtp-server": "^3.13.0",
    "validator": "^13.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
